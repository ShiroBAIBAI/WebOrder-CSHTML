@model Demo.Models.UpdatePasswordVM
@{
    ViewData["Title"] = "Change Password";
    Layout = "_Layout";
}
<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-body p-4">
                <h3 class="mb-4 text-center">Change Password</h3>
                <form asp-action="UpdatePassword" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="Current" class="form-label"></label>
                        <input asp-for="Current" class="form-control" />
                        <span asp-validation-for="Current" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="New" class="form-label"></label>
                        <input asp-for="New" class="form-control" />
                        <span asp-validation-for="New" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Confirm" class="form-label"></label>
                        <input asp-for="Confirm" class="form-control" />
                        <span asp-validation-for="Confirm" class="text-danger"></span>
                    </div>

                    <button class="btn btn-primary w-100">Update</button>
                </form>
            </div>
        </div>
    </div>
</div>
