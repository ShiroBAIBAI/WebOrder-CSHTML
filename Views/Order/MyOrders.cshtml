@model IEnumerable<Demo.Models.Order>

@{
    ViewData["Title"] = "My Orders";
}

<h2>My Orders</h2>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Order #</th>
            <th>Date</th>
            <th>Status</th>
            <th>Total</th>
            <th>Payment</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.OrderId</td>
                <td>@order.CreatedAt.ToString("g")</td>
                <td>@order.Status</td>
                <td>@order.Total.ToString("C")</td>
                <td>@order.PaymentMethod</td>
                <td>
                    <a asp-action="OrderDetails" asp-route-id="@order.OrderId" class="btn btn-sm btn-primary">
                        View Details
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>
