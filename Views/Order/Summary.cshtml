@model Demo.Models.OrderSummaryVM
@{
    ViewData["Title"] = "Order Summary";
    var cart = Model.Cart;
    var p = Model.Price;
}

<h2>Order Summary</h2>

<table class="table">
    <thead>
        <tr><th>Item</th><th style="width:120px">Qty</th><th style="width:140px">Price</th><th style="width:160px">Subtotal</th></tr>
    </thead>
    <tbody>
        @foreach (var kv in cart)
        {
            var ci = kv.Value;
            var sub = ci.Item.Price * ci.Quantity;
            <tr>
                <td>
                    <div class="fw-semibold">@ci.Item.Name</div>
                    <div class="text-muted small">@ci.Options</div>
                </td>
                <td>@ci.Quantity</td>
                <td>RM @ci.Item.Price.ToString("0.00")</td>
                <td>RM @sub.ToString("0.00")</td>
            </tr>
        }
    </tbody>
</table>

<div class="row g-3">
    <div class="col-md-6">
        <form method="post" asp-action="ApplyVoucher" class="d-flex gap-2">
            <input class="form-control" name="voucherCode" value="@Model.VoucherCode" placeholder="Voucher code">
            <button class="btn btn-outline-primary">Apply</button>
            @if (!string.IsNullOrEmpty(Model.VoucherCode))
            {
                <a class="btn btn-outline-secondary" asp-action="ApplyVoucher" asp-route-voucherCode="">Clear</a>
            }
        </form>
    </div>
</div>

<hr />

<div class="row">
    <div class="col-md-6"></div>
    <div class="col-md-6">
        <table class="table table-sm">
            <tr><th>Subtotal</th><td class="text-end">RM @p.Subtotal.ToString("0.00")</td></tr>
            <tr>
                <th>Voucher @(!string.IsNullOrEmpty(p.VoucherCode) ? $"({p.VoucherCode})" : "")</th>
                <td class="text-end text-success">- RM @p.Discount.ToString("0.00")</td>
            </tr>
            <tr><th>Tax (@(p.TaxRate * 100m)% )</th><td class="text-end">RM @p.Tax.ToString("0.00")</td></tr>
            <tr class="table-active"><th>Total</th><td class="text-end fw-bold">RM @p.Total.ToString("0.00")</td></tr>
        </table>
    </div>
</div>

<form method="post" asp-action="Checkout" class="mt-3" id="checkoutForm">
    <div class="pay-section mb-3">
        <h5>Payment Method</h5>
        <div class="pay-hint">Choose your payment method</div>

        <input type="hidden" name="payment" id="payment" value="Cashier" />
        <input type="hidden" name="channel" id="channel" value="" />

        <div class="pay-grid" role="radiogroup" aria-label="Payment Method">
            <button type="button" class="pay-card selected" data-payment="Cashier" data-channel="" role="radio" aria-checked="true">
                <img src="~/images/pay/cash.png" alt="" onerror="this.style.display='none'"><span>Pay at cashier</span>
            </button>

            <button type="button" class="pay-card" data-payment="Online" data-channel="tng" role="radio" aria-checked="false">
                <img src="~/images/pay/tng.png" alt="" onerror="this.style.display='none'"><span>Touch 'n Go</span>
            </button>

            <button type="button" class="pay-card" data-payment="Online" data-channel="grab" role="radio" aria-checked="false">
                <img src="~/images/pay/grab.png" alt="" onerror="this.style.display='none'"><span>GrabPay</span>
            </button>

            <button type="button" class="pay-card" data-payment="Online" data-channel="shopee" role="radio" aria-checked="false">
                <img src="~/images/pay/shopee.png" alt="" onerror="this.style.display='none'"><span>ShopeePay</span>
            </button>

            <button type="button" class="pay-card" data-payment="Online" data-channel="duitnow" role="radio" aria-checked="false">
                <img src="~/images/pay/duitnow.png" alt="" onerror="this.style.display='none'"><span>DuitNow QR</span>
            </button>

            <button type="button" class="pay-card" data-payment="Online" data-channel="fpx" role="radio" aria-checked="false">
                <img src="~/images/pay/fpx.png" alt="" onerror="this.style.display='none'"><span>FPX / Online Banking</span>
            </button>

            <button type="button" class="pay-card pay-card-stripe" data-payment="Online" data-channel="stripe" role="radio" aria-checked="false">
                <img src="~/images/pay/stripe-logo.png" alt="Stripe" onerror="this.style.display='none'">
                <span>Card / Google Play</span>
            </button>
        </div>
    </div>

    @Html.AntiForgeryToken()
    <input type="hidden" name="idempotencyKey" value="@ViewBag.IdempotencyKey" />

    <button class="btn btn-success">Place Order</button>
</form>

@section Scripts {
    <script>
        document.querySelectorAll('.pay-card').forEach(btn=>{
          btn.addEventListener('click', ()=>{
            document.querySelectorAll('.pay-card').forEach(b=>{
              b.classList.remove('selected'); b.setAttribute('aria-checked','false');
            });
            btn.classList.add('selected'); btn.setAttribute('aria-checked','true');
            document.getElementById('payment').value = btn.dataset.payment;
            document.getElementById('channel').value = btn.dataset.channel || '';
          });
        });
    </script>
}

<style>
    .pay-card-stripe {
        border: 1px solid rgba(0,0,0,0.08);
        background: #fff;
        color: #000000;
        display: inline-flex;
        align-items: center;
        padding: 1rem 1.25rem;
        gap: 0.75rem;
        border-radius: 10px;
        box-shadow: none;
        cursor: pointer;
    }

        .pay-card-stripe.selected {
            border-color: #2563eb; 
            box-shadow: 0 0 0 4px rgba(37,99,235,0.12);
            background: linear-gradient(180deg,#ffffff,#f8fbff);
        }

        .pay-card-stripe img {
            height: 26px;
        }

        .pay-card-stripe span {
            font-weight: 600;
            color: #0c4a8a;
        }
</style>