@model Demo.Models.MenuItem
@{
    ViewData["Title"] = "Menu Item Details";
}

<h2>Menu Item Details</h2>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.Name</dd>

    <dt class="col-sm-2">Description</dt>
    <dd class="col-sm-10">@Model.Description</dd>

    <dt class="col-sm-2">Price</dt>
    <dd class="col-sm-10">@Model.Price.ToString("C")</dd>

    <dt class="col-sm-2">Category</dt>
    <dd class="col-sm-10">@Model.Category?.Name</dd>

    <dt class="col-sm-2">Images</dt>
    <dd class="col-sm-10">
        @if (Model.Images != null && Model.Images.Any())
        {
            foreach (var img in Model.Images)
            {
                <img src="@img.Url" width="150" class="me-2 mb-2" />
            }
        }
        else
        {
            <span class="text-muted">No image</span>
        }
    </dd>
</dl>

<a asp-action="Edit" asp-route-id="@Model.MenuItemId" class="btn btn-warning">Edit</a>
<a asp-action="Index" class="btn btn-secondary">Back</a>
