@model Demo.Models.MenuItem
@{
    ViewData["Title"] = "Delete Menu Item";
}

<h2>Delete Menu Item</h2>

<h3>Are you sure you want to delete this?</h3>
<div>
    <strong>@Model.Name</strong><br />
    <span>@Model.Description</span><br />
    <span>Price: @Model.Price</span><br />
    <span>Category: @Model.Category?.Name</span><br />
    @if (Model.Images != null && Model.Images.Any())
    {
        <img src="@Model.Images.First().Url" width="120" />
    }
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="MenuItemId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
