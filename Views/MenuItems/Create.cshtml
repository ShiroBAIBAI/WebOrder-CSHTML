@model Demo.Models.MenuItem
@{
    ViewData["Title"] = "Create Menu Item";
}
<h2>Create Menu Item</h2>

<form asp-action="Create" method="post" enctype="multipart/form-data" class="vstack gap-3">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="MenuCategoryId" class="form-label"></label>
        <select asp-for="MenuCategoryId" class="form-control" asp-items="ViewBag.MenuCategoryId"></select>
        <span asp-validation-for="MenuCategoryId" class="text-danger"></span>
    </div>

    <div>
        <label class="form-label">Name</label>
        <input asp-for="Name" class="form-control" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="Price" class="form-label"></label>
        <input asp-for="Price" class="form-control" type="number" step="0.01" />
        <span asp-validation-for="Price" class="text-danger"></span>
    </div>

    <div>
        <label asp-for="SortOrder" class="form-label"></label>
        <input asp-for="SortOrder" class="form-control" type="number" min="1" />
    </div>

    <div>
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control"></textarea>
    </div>

    <div>
        <label asp-for="Recipe" class="form-label"></label>
        <textarea asp-for="Recipe" class="form-control"></textarea>
    </div>

    <div>
        <label asp-for="Tag" class="form-label"></label>
        <input asp-for="Tag" class="form-control" />
    </div>

    <div>
        <label>Upload Image</label>
        <input type="file" name="imageFile" class="form-control" />
    </div>

    <div class="d-flex gap-2 mt-3">
        <button class="btn btn-primary" type="submit">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
