@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "_Layout";
}
<h2 class="mb-3">Admin Dashboard</h2>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h4>Reports</h4>
                <p class="text-muted">Sales performance and orders.</p>
                <div class="mt-auto">
                    <a asp-action="SalesReport" class="btn btn-primary">Sales Report</a>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100 shadow-sm">
            <div class="card-body d-flex flex-column">
                <h4>Settings</h4>
                <p class="text-muted">Company profile, tax rate, vouchers.</p>
                <div class="mt-auto">
                    <a asp-action="Settings" class="btn btn-success">Open Settings</a>
                </div>
            </div>
        </div>
    </div>
</div>
