@model IEnumerable<Demo.Models.Voucher>
@{
    ViewData["Title"] = "Settings";
    Layout = "_Layout";
}
<h2 class="mb-3">Company & Pricing Settings</h2>

<div class="row">
    <div class="col-lg-6">
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <h4 class="mb-3">Company Profile & Tax</h4>
                <form asp-action="SaveTax" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Company Name</label>
                            <input name="companyName" value="@ViewBag.CompanyName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Company Phone</label>
                            <input name="companyPhone" value="@ViewBag.CompanyPhone" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Company Address</label>
                            <input name="companyAddress" value="@ViewBag.CompanyAddress" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Tax Rate</label>
                            <div class="input-group">
                                <input name="taxRate" value="@ViewBag.TaxRate" class="form-control" />
                                <span class="input-group-text">accept 0.06 or 6</span>
                            </div>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-success">Save</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card mb-4 shadow-sm">
            <div class="card-body">
                <h4 class="mb-3">Create Voucher</h4>
                <form asp-action="CreateVoucher" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-2">
                        <div class="col-md-4">
                            <label class="form-label">Code</label>
                            <input name="Code" class="form-control" placeholder="WELCOME10" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Type</label>
                            <select name="Type" class="form-select">
                                <option value="percent">percent</option>
                                <option value="fixed">fixed</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Amount</label>
                            <input name="Amount" type="number" step="0.01" class="form-control" placeholder="10 or 5.00" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Min Spend</label>
                            <input name="MinSpend" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Expire At</label>
                            <input name="ExpireAt" type="datetime-local" class="form-control" />
                        </div>
                        <input type="hidden" name="Active" value="false" />
                        <div class="col-md-3 d-flex align-items-end">
                            <div class="form-check">
                                <input name="Active" class="form-check-input" type="checkbox" checked />
                                <label class="form-check-label">Active</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <button class="btn btn-primary">Create</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-body">
        <h4 class="mb-3">Vouchers</h4>
        <div class="table-responsive">
            <table class="table table-striped align-middle">
                <thead>
                    <tr>
                        <th>Code</th>
                        <th>Type</th>
                        <th>Amount</th>
                        <th>MinSpend</th>
                        <th>ExpireAt</th>
                        <th>Active</th>
                        <th style="width:180px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var v in Model)
                    {
                        <tr>
                            <td><input name="Code" value="@v.Code" class="form-control" readonly form="f-@v.Code" /></td>
                            <td>
                                <select name="Type" class="form-select" form="f-@v.Code">
                                    <option value="percent" selected="@(v.Type == "percent")">percent</option>
                                    <option value="fixed" selected="@(v.Type == "fixed")">fixed</option>
                                </select>
                            </td>
                            <td><input name="Amount" type="number" step="0.01" value="@v.Amount" class="form-control" form="f-@v.Code" /></td>
                            <td><input name="MinSpend" type="number" step="0.01" value="@(v.MinSpend?.ToString() ?? "")" class="form-control" form="f-@v.Code" /></td>
                            <td><input name="ExpireAt" type="datetime-local" value="@(v.ExpireAt?.ToString("yyyy-MM-ddTHH:mm") ?? "")" class="form-control" form="f-@v.Code" /></td>
                            <td class="text-center">
                                <input type="hidden" name="Active" value="false" form="f-@v.Code" />
                                <input name="Active" type="checkbox" class="form-check-input" value="true" @(v.Active ? "checked" : "") form="f-@v.Code" />
                            </td>
                            <td>
                                <form id="f-@v.Code" asp-action="UpdateVoucher" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="Code" value="@v.Code" />
                                    <button class="btn btn-primary btn-sm">Save</button>
                                </form>
                                <form asp-action="DeleteVoucher" method="post" onsubmit="return confirm('Delete voucher?')" class="d-inline ms-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="code" value="@v.Code" />
                                    <button class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
