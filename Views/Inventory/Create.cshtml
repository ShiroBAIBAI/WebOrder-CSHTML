@model Demo.Models.StockItem
@{
    ViewData["Title"] = "Create Stock Item";
    Layout = "_Layout";
    var cats = new[] { "Produce", "Meat", "Seafood", "Packaging", "Cleaning" };
}
<h2 class="mb-3">@ViewData["Title"]</h2>

<form asp-action="Create" method="post" class="card">
    @Html.AntiForgeryToken()
    <div class="card-body">
        <div class="mb-3">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" placeholder="e.g., Tomato">
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="row g-3">
            <div class="col-sm-4">
                <label asp-for="Unit" class="form-label"></label>
                <input asp-for="Unit" class="form-control" placeholder="e.g., kg / box / pack">
                <span asp-validation-for="Unit" class="text-danger"></span>
            </div>
            <div class="col-sm-4">
                <label asp-for="Quantity" class="form-label"></label>
                <input asp-for="Quantity" class="form-control" type="number" step="1" min="0" value="">
                <div class="form-text">Current on-hand quantity (integer).</div>
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="col-sm-4">
                <label asp-for="ReorderLevel" class="form-label"></label>
                <input asp-for="ReorderLevel" class="form-control" type="number" step="1" min="0" value="">
                <div class="form-text">When on-hand ≤ this level, item is flagged as “Low”.</div>
                <span asp-validation-for="ReorderLevel" class="text-danger"></span>
            </div>
        </div>

        <div class="row g-3 mt-1">
            <div class="col-sm-4">
                <label class="form-label">Category</label>
                <select asp-for="Category" class="form-select">
                    <option value="">(None)</option>
                    @foreach (var c in cats)
                    {
                        <option value="@c">@c</option>
                    }
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>
            <div class="col-sm-4 d-flex align-items-end">
                <div class="form-check">
                    <input asp-for="IsActive" class="form-check-input" />
                    <label asp-for="IsActive" class="form-check-label"></label>
                </div>
            </div>
        </div>
    </div>
    <div class="card-footer d-flex gap-2">
        <button class="btn btn-primary" type="submit">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Back</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
